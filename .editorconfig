root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
tab_width = 2

[*.{md,mdx}]
indent_size = 4

[*.{py,pyi,java,kt,kts,c,cc,cxx,cpp,h,hh,hxx,hpp,cs,fs,fsx,vb,php,rs,swift}]
indent_size = 4

[*.{ps1,psm1,psd1,bat,cmd}]
indent_size = 4

[*.{tex,bib,sty,cls}]
indent_size = 4

[go.mod]
indent_style = tab
indent_size = 4
tab_width = 4

[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

[{Makefile,makefile,*.mk}]
indent_style = tab
indent_size = 4
tab_width = 4
